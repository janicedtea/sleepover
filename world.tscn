[sub_resource type="GDScript" id="GDScript_tlwt5"]
script/source = "extends CharacterBody2D


const SPEED = 300.0
const JUMP_VELOCITY = -500.0

enum FacingDirection {left, right, up, down}
var input_direction = Vector2(0, 0)

@onready var anim_tree = $AnimationTree

func gameover():
	get_tree().reload_current_scene()

func _physics_process(delta: float) -> void:
	# Add the gravity.
	if not is_on_floor():
		velocity += get_gravity() * delta

	# Handle jump.
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = JUMP_VELOCITY

	# Get the input direction and handle the movement/deceleration.
	# As good practice, you should replace UI actions with custom gameplay actions.
	var direction := Input.get_axis(\"ui_left\", \"ui_right\")
	if direction:
		if direction == -1:
			$AnimatedSprite2D2.play(\"right\")
			velocity.x = direction * SPEED
		if direction == 1:
			$AnimatedSprite2D2.play(\"left\")
			velocity.x = direction * SPEED
	else:
		velocity.x = move_toward(velocity.x, 0, SPEED)
		$AnimatedSprite2D2.play(\"default\")

	move_and_slide()
	
	anim_tree.active = true
	


func _process(_delta: float) -> void:
	if interact_target and Input.is_action_just_pressed(\"interact\"):
		interact_target.interact()
	var current_y = global_position.y
	if current_y >= 1000:
		gameover()


func _on_interaction_body_entered(body: Node2D) -> void:
	if body.has_method(\"interact\"):
		interact_target = body


func _on_interaction_body_exited(body: Node2D) -> void:
	if body == interact_target:
		interact_target = null
var interact_target = null


func _on_interaction_area_body_entered(body):
	if body.has_method(\"interact\"):
		interact_target = body

func _on_interaction_area_body_exited(body):
	if body == interact_target:
		interact_target = null
"

